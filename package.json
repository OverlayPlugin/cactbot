{
  "name": "cactbot",
  "version": "0.37.3",
  "releaseSummary": "Windhurst timeline, more UMAD, i18n",
  "releaseInDraft": "false",
  "license": "Apache-2.0",
  "type": "module",
  "types": "./types",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OverlayPlugin/cactbot.git"
  },
  "files": [
    "./ui",
    "./types",
    "./util",
    "./resources",
    "package.json"
  ],
  "scripts": {
    "build": "cross-env TS_NODE_PROJECT=\"tsconfig.webpack.json\" webpack --progress --config webpack/webpack.prod.ts",
    "build-gh-pages": "cross-env TS_NODE_PROJECT=\"tsconfig.webpack.json\" webpack --config webpack/webpack.ghpages.ts",
    "start": "cross-env TS_NODE_PROJECT=\"tsconfig.webpack.json\" webpack serve --config webpack/webpack.dev.ts",
    "fetch-deps": "node --loader=ts-node/esm ./util/fetch_deps.ts",
    "tsc-no-emit": "tsc --noEmit",
    "lint": "run-s lint:**",
    "lint:dprint": "dprint check",
    "lint:eslint": "cross-env-shell \"NODE_OPTIONS=$NODE_OPTIONS --experimental-strip-types\" eslint --flag unstable_native_nodejs_ts_config --max-warnings=0 ./",
    "lintfix": "run-s lintfix:**",
    "lintfix:dprint": "dprint fmt",
    "lintfix:eslint": "cross-env-shell \"NODE_OPTIONS=$NODE_OPTIONS --experimental-strip-types\" eslint --flag unstable_native_nodejs_ts_config --max-warnings=0 --fix ./",
    "stylelint": "stylelint \"resources/**/*.css\" \"ui/**/*.css\" \"user/**/*.css\" \"test/**/*.css\" \"util/**/*.css\"",
    "stylelintfix": "stylelint --fix \"resources/**/*.css\" \"ui/**/*.css\" \"user/**/*.css\" \"test/**/*.css\" \"util/**/*.css\"",
    "markdownlint": "markdownlint . --ignore node_modules --ignore publish --ignore plugin/ThirdParty",
    "workflowlint": "yamllint -c .yamllint.yml .github/workflows/ && node .github/scripts/lint-workflow.cjs",
    "test": "mocha",
    "sync-files": "node --loader=ts-node/esm util/sync_files.ts && git diff --exit-code",
    "lint-staged": "lint-staged",
    "coverage-report": "node --loader=ts-node/esm util/gen_coverage_report.ts",
    "util": "node --loader=ts-node/esm util/index.ts",
    "find-translations": "npm run util -- findTranslations",
    "translate-timeline": "npm run util -- translateTimeline",
    "generate": "npm run util -- generate",
    "query": "npm run util -- query",
    "process-triggers": "node --loader=ts-node/esm util/process_triggers_folder.ts",
    "generate-log-guide": "node --loader=ts-node/esm util/gen_log_guide.ts",
    "update-logdefs": "node --loader=ts-node/esm util/update_logdefs.ts",
    "validate-versions": "node --loader=ts-node/esm util/validate_versions.ts",
    "release": "node --loader=ts-node/esm util/do_release.ts",
    "version": "node --loader=ts-node/esm util/bump_version.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@actions/http-client": "^4.0.1",
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-typescript": "^8.0.1",
    "@dprint/json": "^0.21.3",
    "@dprint/typescript": "^0.96.1",
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-paginate-rest": "^14.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/argparse": "^2.0.17",
    "@types/chai": "^5.2.3",
    "@types/inquirer": "^9.0.10",
    "@types/inquirer-fuzzy-path": "^2.3.9",
    "@types/is-ci": "^3.0.4",
    "@types/lodash": "^4.17.24",
    "@types/markdown-magic": "^1.0.4",
    "@types/mini-css-extract-plugin": "^2.5.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "@types/node-fetch": "^2.6.13",
    "@types/tar-fs": "^2.0.4",
    "@types/webpack": "^5.28.5",
    "babel-loader": "^10.1.1",
    "chai": "^6.2.2",
    "chalk": "^5.6.2",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "dprint": "^0.54.0",
    "eslint": "^9.39.4",
    "eslint-config-google": "^0.14.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "eslint-plugin-rulesdir": "^0.2.2",
    "eslint-plugin-tsc": "^2.0.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "fast-levenshtein": "^3.0.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "fs-extra": "^11.3.5",
    "globals": "^17.7.0",
    "html-webpack-plugin": "^5.6.7",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "jsdom-global": "^3.0.2",
    "json5": "^2.2.3",
    "jszip": "^3.10.1",
    "lint-staged": "^17.0.8",
    "markdown-magic": "^4.9.0",
    "markdownlint-cli": "^0.49.0",
    "mini-css-extract-plugin": "^2.10.2",
    "mocha": "^11.7.6",
    "node-fetch": "^3.3.2",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.15",
    "proxy-agent": "^8.0.2",
    "recast": "^0.23.11",
    "simple-git": "^3.36.0",
    "style-loader": "^4.0.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "tar-fs": "^3.1.2",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.5",
    "webpack-merge": "^6.0.1"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "stylelint": {
    "extends": "stylelint-config-standard"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint-staged"
    }
  },
  "lint-staged": {
    "*.css": "stylelint",
    "*.{ts,js,cjs,mjs,json}": [
      "dprint check"
    ],
    "*.{js,cjs,mjs}": [
      "eslint --max-warnings=0"
    ],
    "*.ts": [
      "eslint --max-warnings=0 --plugin tsc --rule 'tsc/config: [2, {configFile: \"./tsconfig.eslint.json\"}]'"
    ],
    "*.md": "markdownlint",
    "ui/(raidboss|oopsyraidsy)/data/**": [
      "node --loader=ts-node/esm test/test_data_files.ts"
    ]
  },
  "dependencies": {
    "@fast-csv/parse": "^5.0.7",
    "argparse": "^2.0.1",
    "dexie": "^4.4.4",
    "dexie-export-import": "^4.4.0",
    "eventemitter3": "^5.0.4",
    "inquirer": "^14.0.2",
    "inquirer-fuzzy-path": "^2.3.0",
    "lodash": "^4.18.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
